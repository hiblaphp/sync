{
    "name": "hiblaphp/sync",
    "description": "Non-blocking synchronization primitives (Mutex, Semaphore) for async PHP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Sync\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "hiblaphp/event-loop": "^1.0",
        "hiblaphp/promise": "^1.0",
        "hiblaphp/cancellation": "^1.0",
        "hiblaphp/async": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "laravel/pint": "^1.25"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint",
        "analyze": "vendor/bin/phpstan analyse"
    }
}